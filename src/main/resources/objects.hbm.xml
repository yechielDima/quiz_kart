<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">


<hibernate-mapping>
    <class name="com.ashcollege.entities.UserEntity" table="users" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <property name="deleted" type="boolean">
            <column name="deleted" default="false"/>
        </property>

        <property name="creationDate" type="timestamp" update="false" generated="insert">
            <column name="creation_date" default="CURRENT_TIMESTAMP" />
        </property>
        <property name="username" type="string" column="username"/>
        <property name="password" type="string" column="password"/>
        <property name="fullName" type="string" column="full_name"/>
        <property name="token" type="string" column="token"/>
    </class>

    <class name="com.ashcollege.entities.GameEntity" table="games" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <property name="deleted" type="boolean">
            <column name="deleted" default="false"/>
        </property>
        <property name="creationDate" type="timestamp" update="false" generated="insert">
            <column name="creation_date" default="CURRENT_TIMESTAMP" />
        </property>
        <property name="startedAt" type="timestamp" column="started_at"/>
        <property name="finishedAt" type="timestamp" column="finished_at"/>
        <property name="maxPlayers" type="int" column="max_players"/>
        <property name="trackLength" type="int" column="track_length"/>
        <property name="gameName" type="string" column="game_name"/>
        <many-to-one name="creator"
                     column="creator_id"
                     class="com.ashcollege.entities.UserEntity"
                     not-null="true" />

        <property name="gameType" type="int" column="game_type"/>

        <property name="gameCode" type="string">
            <column name="game_code" not-null="true" unique="true"/>
        </property>


        <property name="status" type="int" column="status"/>
    </class>

    <class name="com.ashcollege.entities.GamePlayerEntity" table="game_players" lazy="false">
        <id name="id" type="int" column="id">
            <generator class="native"/>
        </id>
        <property name="deleted" type="boolean">
            <column name="deleted" default="false"/>
        </property>
        <property name="creationDate" type="timestamp" update="false" generated="insert">
            <column name="creation_date" default="CURRENT_TIMESTAMP" />
        </property>
        <property name="correctAnswers" type="int" column="correct_answers"/>
        <property name="wrongAnswers" type="int" column="wrong_answers"/>
        <property name="streak" type="int" column="streak"/>
        <property name="finished" type="boolean" column="finished"/>
        <property name="finishTime" type="timestamp" column="finish_time"/>

        <many-to-one name="player"
                     column="player_id"
                     class="com.ashcollege.entities.UserEntity"
                     not-null="true" />
        <many-to-one name="game"
                     column="game_id"
                     class="com.ashcollege.entities.GameEntity"
                     not-null="true" />

        <property name="score" type="int" column="score"/>
    </class>


</hibernate-mapping>
